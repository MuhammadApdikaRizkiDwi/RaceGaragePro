<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏁 RACEGARAGE PRO"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="32sp"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MotoGP Racing Workshop"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:layout_marginBottom="25dp"/>

        <!-- PROMO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 PROMO RACEGARAGE PRO"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diskon 30% Tune Up Racing!"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- SPAREPART -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛠 Sparepart Racing Baru"
                android:textColor="#00E5FF"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• ECU Racing\n• Ban Slick MotoGP\n• Knalpot Titanium\n• Oli Racing Premium"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- BUTTON BOOKING -->
        <Button
            android:id="@+id/btnBookingNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Booking Servis Sekarang"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#D50000"
            android:layout_marginTop="10dp"/>

        <!-- BUTTON SHOP -->
        <Button
            android:id="@+id/btnShop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shop Sparepart Racing"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#2962FF"
            android:layout_marginTop="15dp"/>

        <!-- BUTTON MAPS -->
        <Button
            android:id="@+id/btnMapsHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lokasi Workshop"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#00C853"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>